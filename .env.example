# ==============================================================================
# ENTERPRISE FORENSICS PLATFORM ENVIRONMENT VARIABLES TEMPLATE (.env.example)
# ==============================================================================

# 1. Core Profile
ENV=production
PROJECT_NAME="Deepfake Forensics Platform"
DEBUG=False
SECRET_KEY="generate-a-secure-32-byte-hex-string-for-tokens"

# 2. Database Dialects
DATABASE_URL="postgresql://user:password@localhost:5432/forensics"
MONGO_URI="mongodb://user:password@localhost:27017/forensics"

# 3. Size Limits & Whitelists
MAX_UPLOAD_SIZE_MB=100
ALLOWED_EXTENSIONS="mp4,avi,mov,mkv,mp3,wav"
JWT_EXPIRY_MINUTES=60

# 4. Model Context configuration
USE_GPU=True
CUDA_DEVICE_ID=0
FUSION_STRATEGY="late_average"

# 5. Telemetry metrics & MLOps API configurations
PROMETHEUS_METRICS_ENABLED=True
LOG_LEVEL="INFO"
MLFLOW_TRACKING_URI="http://localhost:5000"
WANDB_API_KEY="your-wandb-api-key"
